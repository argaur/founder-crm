# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from: Telegram → @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# The username of your bot WITHOUT the @ (e.g. foundercrm_bot)
# Used to construct deep links: https://t.me/{BOT_NAME}?start={user_id}
BOT_NAME=

# ── Database (Neon Postgres) ────────────────────────────────────────────────────
# Pooled connection string from your Neon project dashboard.
DATABASE_URL=

# ── AI ─────────────────────────────────────────────────────────────────────────
# OpenAI — single key for both extraction/reasoning (gpt-4o-mini) and voice
# transcription (Whisper). Get from: platform.openai.com
OPENAI_API_KEY=

# ── Dashboard auth ─────────────────────────────────────────────────────────────
# HMAC key for signed dashboard tokens (any long random hex string).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_TOKEN_SECRET=

# ── App ────────────────────────────────────────────────────────────────────────
# Public URL of this Railway service (no trailing slash)
# Set AFTER deploying to Railway — Railway shows you the URL in the dashboard
# Example: https://founder-crm-production.up.railway.app
APP_BASE_URL=
